---
import { COPY, ROLES, TEAM_COLOR, TEAM_LABEL, PLAY_URL, type Lang } from "../i18n/copy";
import Icon from "./Icon.astro";
interface Props { lang?: Lang }
const { lang = "uz" } = Astro.props;
const t = COPY[lang].hero;
const teamLabel = TEAM_LABEL[lang];

// A "hand" of dealt role cards is the hero visual — you've been dealt in.
// Picked for colour spread + drama; the centre card sits highest.
const fanRoles = [4, 2, 1, 0, 5].map((i) => ROLES[i]); // Doctor, Komissar, Mafia(center), Don, Maniac
const fan = fanRoles.map((role, i) => {
  const o = i - (fanRoles.length - 1) / 2; // -2 … 2
  return {
    role,
    rot: o * 12,
    x: o * 62,
    y: Math.abs(o) * 22,
    z: 10 - Math.abs(o) * 2,
    s: o === 0 ? 1.08 : 1,
    center: o === 0,
  };
});

const teams = ["MAFIA", "CIVIL", "NEUTRAL"] as const;
---

<section class="hero" id="hero">
  <!-- ambience layers -->
  <div class="moon" aria-hidden="true"></div>
  <div class="fog fog-1" aria-hidden="true"></div>
  <div class="fog fog-2" aria-hidden="true"></div>
  <div class="embers" aria-hidden="true">
    {Array.from({ length: 14 }).map((_, i) => (
      <span style={`--i:${i}; left:${(i * 7 + 4) % 100}%; animation-delay:${(i * 0.9).toFixed(1)}s; animation-duration:${(7 + (i % 5)).toFixed(0)}s;`}></span>
    ))}
  </div>

  <div class="hero-inner">
    <div class="hero-content">
      <span class="hero-badge fade-in">
        <span class="live-dot"></span>{t.badge}
      </span>
      <h1 class="hero-title font-display fade-in">
        {t.titleA}<br />
        <span class="hero-hi">{t.titleHi}</span> {t.titleB}
      </h1>
      <p class="hero-desc fade-in">{t.desc}</p>

      <div class="hero-buttons fade-in">
        <a href={PLAY_URL} class="btn-primary btn-pulse" target="_blank" rel="noopener">
          <Icon name="play" size={17} /> {t.play}
        </a>
        <a href="#roles" class="btn-secondary">{t.secondary} <Icon name="arrow-down" size={17} /></a>
      </div>

      <div class="hero-meta fade-in">
        <div class="hero-live">
          <span class="live-dot"></span>
          <strong data-count="248">248</strong>&nbsp;{t.live}
        </div>
        <span class="hero-sep" aria-hidden="true"></span>
        <ul class="team-legend">
          {teams.map((tm) => (
            <li style={`--tc:${TEAM_COLOR[tm]};`}><span class="tl-dot"></span>{teamLabel[tm]}</li>
          ))}
        </ul>
      </div>
    </div>

    <!-- Dealt hand of role cards -->
    <div class="hero-visual fade-in" aria-hidden="true">
      <div class="deck-glow"></div>
      <div class="fan-stage">
        <div class="card-fan">
          {fan.map((c) => (
            <article
              class:list={["deal-card", { center: c.center }]}
              style={`--c:${c.role.color}; --tc:${TEAM_COLOR[c.role.team]}; --rot:${c.rot}deg; --x:${c.x}px; --y:${c.y}px; --z:${c.z}; --s:${c.s};`}
            >
              <Icon name={c.role.icon} size={88} stroke={1} class="deal-watermark" />
              <div class="deal-medallion">
                <Icon name={c.role.icon} size={26} stroke={1.8} />
              </div>
              <span class="deal-name font-display">{c.role[lang].name}</span>
              <span class="deal-team">{teamLabel[c.role.team]}</span>
            </article>
          ))}
        </div>
      </div>
    </div>
  </div>

  <!-- AEO direct answer (visible, concise) -->
  <p class="hero-answer fade-in">{t.answer}</p>
</section>

<style>
  .hero {
    min-height: 100vh;
    display: flex;
    flex-direction: column;
    justify-content: center;
    align-items: center;
    position: relative;
    padding: 150px 24px 60px;
    overflow: hidden;
  }

  /* ── ambience ── */
  .moon {
    position: absolute;
    top: 8%; right: 12%;
    width: 160px; height: 160px;
    border-radius: 50%;
    background: radial-gradient(circle at 38% 38%, #FCE08A, #D4AF37 55%, #8a6d18 100%);
    box-shadow: 0 0 90px 20px rgba(212, 175, 55, 0.25);
    opacity: 0.5;
    animation: float 9s ease-in-out infinite;
  }
  .fog {
    position: absolute;
    left: -20%; width: 140%; height: 320px;
    background: radial-gradient(ellipse at center, rgba(196, 30, 58, 0.10), transparent 70%);
    filter: blur(20px);
    pointer-events: none;
  }
  .fog-1 { bottom: -60px; animation: fog-drift 26s linear infinite; }
  .fog-2 { top: 20%; background: radial-gradient(ellipse at center, rgba(124, 58, 237, 0.10), transparent 70%); animation: fog-drift 34s linear infinite reverse; }
  @keyframes fog-drift { 0% { transform: translateX(-6%); } 50% { transform: translateX(6%); } 100% { transform: translateX(-6%); } }

  .embers { position: absolute; inset: 0; pointer-events: none; }
  .embers span {
    position: absolute;
    bottom: -10px;
    width: 4px; height: 4px;
    border-radius: 50%;
    background: var(--gold-light);
    box-shadow: 0 0 8px 2px rgba(212, 175, 55, 0.6);
    opacity: 0;
    animation: ember-rise linear infinite;
  }
  @keyframes ember-rise {
    0% { transform: translateY(0) scale(1); opacity: 0; }
    15% { opacity: 0.9; }
    100% { transform: translateY(-86vh) scale(0.3); opacity: 0; }
  }

  /* ── content ── */
  .hero-inner {
    max-width: var(--maxw);
    width: 100%;
    margin: 0 auto;
    display: flex;
    align-items: center;
    gap: 40px;
    position: relative;
    z-index: 2;
  }
  .hero-content { flex: 1; min-width: 0; }

  .hero-badge {
    display: inline-flex;
    align-items: center;
    gap: 9px;
    padding: 7px 16px;
    background: rgba(196, 30, 58, 0.1);
    border: 1px solid rgba(196, 30, 58, 0.3);
    border-radius: 50px;
    font-size: 0.85rem;
    font-weight: 600;
    color: var(--text);
    margin-bottom: 24px;
  }
  .live-dot {
    width: 9px; height: 9px; border-radius: 50%;
    background: #2ee06a;
    box-shadow: 0 0 0 0 rgba(46, 224, 106, 0.6);
    animation: live-ping 1.8s ease-out infinite;
    flex: none;
  }
  @keyframes live-ping {
    0% { box-shadow: 0 0 0 0 rgba(46, 224, 106, 0.55); }
    100% { box-shadow: 0 0 0 9px rgba(46, 224, 106, 0); }
  }

  .hero-title {
    font-size: clamp(2.6rem, 6vw, 4.4rem);
    font-weight: 900;
    line-height: 1.06;
    letter-spacing: 1px;
    margin-bottom: 22px;
    text-shadow: 0 4px 30px rgba(0, 0, 0, 0.5);
  }
  .hero-hi {
    background: var(--gradient);
    -webkit-background-clip: text;
    background-clip: text;
    -webkit-text-fill-color: transparent;
    filter: drop-shadow(0 0 26px rgba(196, 30, 58, 0.45));
  }

  .hero-desc {
    font-size: 1.18rem;
    color: var(--text-muted);
    max-width: 540px;
    line-height: 1.75;
    margin-bottom: 34px;
  }
  .hero-buttons { display: flex; gap: 16px; flex-wrap: wrap; margin-bottom: 28px; }
  .hero-buttons :global(svg) { flex: none; }

  /* live + team legend row */
  .hero-meta {
    display: flex;
    align-items: center;
    gap: 18px;
    flex-wrap: wrap;
  }
  .hero-live {
    display: inline-flex;
    align-items: center;
    gap: 10px;
    font-size: 0.95rem;
    color: var(--text-muted);
  }
  .hero-live strong { color: var(--text); font-variant-numeric: tabular-nums; }
  .hero-sep { width: 1px; height: 20px; background: var(--border); }
  .team-legend { display: flex; gap: 16px; list-style: none; flex-wrap: wrap; }
  .team-legend li {
    display: inline-flex; align-items: center; gap: 7px;
    font-size: 0.85rem; font-weight: 600; color: var(--text-muted);
  }
  .tl-dot { width: 8px; height: 8px; border-radius: 50%; background: var(--tc); box-shadow: 0 0 10px var(--tc); }

  /* ── dealt hand visual ── */
  .hero-visual {
    flex: 0 0 auto;
    position: relative;
    display: grid;
    place-items: center;
    width: 460px; height: 420px;
  }
  .deck-glow {
    position: absolute;
    width: 320px; height: 320px;
    border-radius: 50%;
    background: radial-gradient(circle, rgba(196, 30, 58, 0.22), transparent 65%);
    filter: blur(10px);
    animation: glow-pulse 4s ease-in-out infinite;
  }
  .fan-stage { position: relative; }
  .card-fan {
    position: relative;
    width: 180px; height: 240px;
    animation: float 7s ease-in-out infinite;
  }

  .deal-card {
    position: absolute;
    inset: 0;
    width: 180px; height: 240px;
    padding: 20px 18px;
    border-radius: 20px;
    background:
      radial-gradient(circle at 80% -10%, color-mix(in srgb, var(--c) 30%, transparent), transparent 60%),
      linear-gradient(165deg, var(--card-hover), #0b0b12);
    border: 1px solid color-mix(in srgb, var(--c) 38%, var(--border));
    box-shadow:
      0 30px 60px -24px rgba(0, 0, 0, 0.9),
      inset 0 1px 0 rgba(255, 255, 255, 0.05);
    overflow: hidden;
    transform-origin: bottom center;
    transform: translate(var(--x), var(--y)) rotate(var(--rot)) scale(var(--s));
    z-index: var(--z);
    transition: transform 0.35s cubic-bezier(.2,.7,.2,1), box-shadow 0.35s, border-color 0.35s;
  }
  .deal-card::before {
    content: "";
    position: absolute;
    inset: 0 0 auto 0;
    height: 3px;
    background: linear-gradient(90deg, transparent, var(--c), transparent);
  }
  .deal-card:hover {
    transform: translate(var(--x), calc(var(--y) - 18px)) rotate(var(--rot)) scale(calc(var(--s) + 0.05));
    border-color: color-mix(in srgb, var(--c) 70%, transparent);
    box-shadow: 0 36px 70px -26px color-mix(in srgb, var(--c) 75%, black);
    z-index: 30;
  }
  .deal-card.center {
    box-shadow:
      0 36px 70px -22px color-mix(in srgb, var(--c) 60%, black),
      0 0 0 1px color-mix(in srgb, var(--c) 30%, transparent);
  }

  .deal-watermark {
    position: absolute;
    right: -14px; bottom: -14px;
    color: var(--c);
    opacity: 0.1;
  }
  .deal-medallion {
    position: relative;
    z-index: 1;
    width: 52px; height: 52px;
    border-radius: 14px;
    display: grid; place-items: center;
    color: var(--c);
    background:
      linear-gradient(160deg, color-mix(in srgb, var(--c) 26%, transparent), color-mix(in srgb, var(--c) 6%, transparent)),
      var(--bg-3);
    border: 1px solid color-mix(in srgb, var(--c) 48%, transparent);
    box-shadow: 0 8px 22px -8px var(--c);
    margin-bottom: 60px;
  }
  .deal-name {
    position: relative;
    z-index: 1;
    display: block;
    font-size: 1.15rem;
    font-weight: 700;
    color: var(--text);
    line-height: 1.2;
    margin-bottom: 6px;
  }
  .deal-team {
    position: relative;
    z-index: 1;
    font-size: 0.66rem;
    font-weight: 700;
    text-transform: uppercase;
    letter-spacing: 1.5px;
    color: var(--tc);
  }

  /* AEO answer */
  .hero-answer {
    position: relative;
    z-index: 2;
    max-width: 760px;
    margin: 48px auto 0;
    text-align: center;
    color: var(--text-dim);
    font-size: 0.98rem;
    line-height: 1.7;
    padding: 16px 22px;
    border: 1px solid var(--border-light);
    border-radius: var(--radius-sm);
    background: rgba(255, 255, 255, 0.015);
  }

  @media (max-width: 980px) {
    .hero-inner { flex-direction: column; text-align: center; gap: 52px; }
    .hero-desc { margin-left: auto; margin-right: auto; }
    .hero-buttons { justify-content: center; }
    .hero-meta { justify-content: center; }
    .hero-visual { width: 100%; height: 380px; }
    .fan-stage { transform: scale(0.92); }
  }
  @media (max-width: 560px) {
    .hero { padding: 130px 16px 50px; }
    .moon { width: 100px; height: 100px; top: 6%; right: 8%; }
    .hero-visual { height: 330px; }
    .fan-stage { transform: scale(0.66); }
    .hero-sep { display: none; }
    .hero-buttons :global(.btn-primary), .hero-buttons :global(.btn-secondary) { width: 100%; justify-content: center; }
  }
</style>

<script>
  // Count-up for the live players figure when it scrolls into view.
  const el = document.querySelector<HTMLElement>(".hero-live strong[data-count]");
  if (el) {
    const target = parseInt(el.dataset.count || "0", 10);
    let started = false;
    const run = () => {
      if (started) return;
      started = true;
      const start = performance.now();
      const dur = 1400;
      const tick = (now: number) => {
        const p = Math.min((now - start) / dur, 1);
        el.textContent = Math.floor(p * target).toString();
        if (p < 1) requestAnimationFrame(tick);
      };
      requestAnimationFrame(tick);
    };
    new IntersectionObserver((e, o) => {
      if (e[0].isIntersecting) { run(); o.disconnect(); }
    }).observe(el);
  }
</script>
