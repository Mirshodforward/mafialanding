---
import { COPY, ROLES, TEAM_COLOR, TEAM_LABEL, type Lang } from "../i18n/copy";
import Icon from "./Icon.astro";
interface Props { lang?: Lang }
const { lang = "uz" } = Astro.props;
const t = COPY[lang].rolesSection;
const teamLabel = TEAM_LABEL[lang];
---

<section id="roles">
  <div class="container">
    <div class="section-header fade-in">
      <span class="section-label">{t.label}</span>
      <h2 class="section-title">{t.title}</h2>
      <p class="section-subtitle">{t.subtitle}</p>
    </div>

    <div class="roles-grid">
      {ROLES.map((role, i) => (
        <article
          class="role-card fade-in"
          style={`--c:${role.color}; --tc:${TEAM_COLOR[role.team]}; transition-delay:${(i % 4) * 60}ms;`}
        >
          <span class="role-sheen" aria-hidden="true"></span>
          <Icon name={role.icon} size={130} stroke={1} class="role-watermark" />
          <span class="role-index font-display">{String(i + 1).padStart(2, "0")}</span>

          <div class="role-medallion">
            <Icon name={role.icon} size={30} stroke={1.8} />
          </div>

          <span class="role-team">
            <span class="role-team-dot"></span>{teamLabel[role.team]}
          </span>

          <h3 class="role-name font-display">{role[lang].name}</h3>
          <p class="role-desc">{role[lang].desc}</p>
        </article>
      ))}
    </div>
  </div>
</section>

<style>
  .roles-grid {
    display: grid;
    grid-template-columns: repeat(auto-fill, minmax(252px, 1fr));
    gap: 20px;
  }

  .role-card {
    position: relative;
    padding: 24px 22px 22px;
    background:
      radial-gradient(circle at 82% -20%, color-mix(in srgb, var(--c) 22%, transparent), transparent 58%),
      linear-gradient(160deg, var(--card-hover), var(--card));
    border: 1px solid var(--border-light);
    border-radius: var(--radius);
    overflow: hidden;
    isolation: isolate;
    transition: transform 0.3s cubic-bezier(.2,.7,.2,1), border-color 0.3s, box-shadow 0.3s, opacity 0.7s, translate 0.7s;
  }
  /* top accent rail in the role colour */
  .role-card::before {
    content: "";
    position: absolute;
    inset: 0 0 auto 0;
    height: 3px;
    background: linear-gradient(90deg, transparent, var(--c), transparent);
    opacity: 0.85;
  }
  .role-card:hover {
    transform: translateY(-8px);
    border-color: color-mix(in srgb, var(--c) 60%, transparent);
    box-shadow:
      0 22px 50px -18px color-mix(in srgb, var(--c) 70%, transparent),
      inset 0 0 0 1px color-mix(in srgb, var(--c) 18%, transparent);
  }

  /* light sweep across the card on hover */
  .role-sheen {
    position: absolute;
    inset: 0;
    z-index: 3;
    background: linear-gradient(115deg, transparent 38%, color-mix(in srgb, var(--c) 22%, transparent) 50%, transparent 62%);
    transform: translateX(-120%);
    transition: transform 0.7s ease;
    pointer-events: none;
  }
  .role-card:hover .role-sheen { transform: translateX(120%); }

  /* faint suit-like watermark icon, bottom-right */
  .role-watermark {
    position: absolute;
    right: -22px; bottom: -26px;
    color: var(--c);
    opacity: 0.07;
    z-index: 0;
    transition: opacity 0.3s, transform 0.3s;
  }
  .role-card:hover .role-watermark { opacity: 0.14; transform: rotate(-6deg) scale(1.05); }

  /* playing-card corner index */
  .role-index {
    position: absolute;
    top: 16px; right: 18px;
    font-size: 1.05rem;
    font-weight: 800;
    letter-spacing: 1px;
    color: color-mix(in srgb, var(--c) 70%, var(--text-dim));
    opacity: 0.55;
    z-index: 2;
  }

  .role-medallion {
    position: relative;
    z-index: 2;
    width: 58px; height: 58px;
    border-radius: 15px;
    display: grid; place-items: center;
    color: var(--c);
    background:
      linear-gradient(160deg, color-mix(in srgb, var(--c) 24%, transparent), color-mix(in srgb, var(--c) 6%, transparent)),
      var(--bg-3);
    border: 1px solid color-mix(in srgb, var(--c) 45%, transparent);
    box-shadow: 0 8px 24px -10px var(--c), inset 0 1px 0 color-mix(in srgb, var(--c) 30%, transparent);
    margin-bottom: 16px;
  }

  .role-team {
    position: relative;
    z-index: 2;
    display: inline-flex;
    align-items: center;
    gap: 6px;
    font-size: 0.68rem;
    font-weight: 700;
    text-transform: uppercase;
    letter-spacing: 1.2px;
    padding: 4px 11px 4px 9px;
    border-radius: 50px;
    color: var(--tc);
    background: color-mix(in srgb, var(--tc) 14%, transparent);
    border: 1px solid color-mix(in srgb, var(--tc) 35%, transparent);
    margin-bottom: 14px;
  }
  .role-team-dot {
    width: 6px; height: 6px; border-radius: 50%;
    background: var(--tc);
    box-shadow: 0 0 8px var(--tc);
  }

  .role-name {
    position: relative;
    z-index: 2;
    font-size: 1.3rem;
    font-weight: 700;
    margin-bottom: 8px;
    color: var(--text);
  }
  .role-desc {
    position: relative;
    z-index: 2;
    color: var(--text-muted);
    font-size: 0.92rem;
    line-height: 1.65;
  }

  @media (max-width: 480px) {
    .roles-grid { grid-template-columns: 1fr; }
  }
</style>
