---
import { Image } from "astro:assets";
import type { ImageMetadata } from "astro";
import { COPY, ROLES, TEAM_COLOR, TEAM_LABEL, type Lang } from "../i18n/copy";
import Icon from "./Icon.astro";
interface Props { lang?: Lang }
const { lang = "uz" } = Astro.props;
const t = COPY[lang].rolesSection;
const teamLabel = TEAM_LABEL[lang];
const roleWord = lang === "ru" ? "роль в Mafia Online" : "Mafia Online roli";

// Eagerly load every role card illustration so Astro optimises them at build
// (full-size PNG → lightweight responsive WebP). Keyed by base filename.
const artFiles = import.meta.glob<{ default: ImageMetadata }>(
  "../assets/rollar/*.png",
  { eager: true },
);
const artFor = (name?: string) =>
  name ? artFiles[`../assets/rollar/${name}.png`]?.default : undefined;
---

<section id="roles">
  <div class="container">
    <div class="section-header fade-in">
      <span class="section-label">{t.label}</span>
      <h2 class="section-title">{t.title}</h2>
      <p class="section-subtitle">{t.subtitle}</p>
    </div>

    <div class="roles-grid">
      {ROLES.map((role, i) => {
        const art = artFor(role.img);
        return (
          <article
            class="role-card fade-in"
            style={`--c:${role.color}; --tc:${TEAM_COLOR[role.team]}; transition-delay:${(i % 4) * 60}ms;`}
          >
            <div class={`role-art${art ? "" : " role-art--icon"}`}>
              {art ? (
                <Image
                  src={art}
                  alt={`${role[lang].name} — ${roleWord}`}
                  class="role-img"
                  widths={[220, 320, 480]}
                  sizes="(max-width: 480px) 92vw, 280px"
                  format="webp"
                  quality={72}
                  loading="lazy"
                  decoding="async"
                />
              ) : (
                <Icon name={role.icon} size={92} stroke={1.2} class="role-art-fallback" />
              )}

              <span class="role-sheen" aria-hidden="true"></span>
              <span class="role-index font-display">{String(i + 1).padStart(2, "0")}</span>

              <span class="role-team">
                <span class="role-team-dot"></span>{teamLabel[role.team]}
              </span>
            </div>

            <div class="role-body">
              <h3 class="role-name font-display">{role[lang].name}</h3>
              <p class="role-desc">{role[lang].desc}</p>
            </div>
          </article>
        );
      })}
    </div>
  </div>
</section>

<style>
  .roles-grid {
    display: grid;
    grid-template-columns: repeat(auto-fill, minmax(240px, 1fr));
    gap: 20px;
  }

  .role-card {
    position: relative;
    display: flex;
    flex-direction: column;
    background: linear-gradient(160deg, var(--card-hover), var(--card));
    border: 1px solid var(--border-light);
    border-radius: var(--radius);
    overflow: hidden;
    isolation: isolate;
    transition: transform 0.3s cubic-bezier(.2,.7,.2,1), border-color 0.3s, box-shadow 0.3s, opacity 0.7s, translate 0.7s;
  }
  /* top accent rail in the role colour */
  .role-card::before {
    content: "";
    position: absolute;
    inset: 0 0 auto 0;
    height: 3px;
    z-index: 4;
    background: linear-gradient(90deg, transparent, var(--c), transparent);
    opacity: 0.85;
  }
  .role-card:hover {
    transform: translateY(-8px);
    border-color: color-mix(in srgb, var(--c) 60%, transparent);
    box-shadow:
      0 22px 50px -18px color-mix(in srgb, var(--c) 70%, transparent),
      inset 0 0 0 1px color-mix(in srgb, var(--c) 18%, transparent);
  }

  /* ── Card art ───────────────────────────────────────────────── */
  .role-art {
    position: relative;
    aspect-ratio: 3 / 4;
    overflow: hidden;
    background:
      radial-gradient(circle at 50% 22%, color-mix(in srgb, var(--c) 30%, transparent), transparent 62%),
      linear-gradient(160deg, var(--bg-3), var(--card));
  }
  .role-img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    object-position: center top;
    display: block;
    transition: transform 0.5s cubic-bezier(.2,.7,.2,1);
  }
  .role-card:hover .role-img { transform: scale(1.06); }

  /* fade the bottom of the art into the card body */
  .role-art::after {
    content: "";
    position: absolute;
    inset: auto 0 0 0;
    height: 42%;
    background: linear-gradient(to top, var(--card) 4%, transparent);
    pointer-events: none;
    z-index: 2;
  }

  /* fallback when a role has no illustration (e.g. Townsperson) */
  .role-art--icon { display: grid; place-items: center; }
  .role-art-fallback { color: var(--c); opacity: 0.85; filter: drop-shadow(0 8px 24px color-mix(in srgb, var(--c) 60%, transparent)); }

  /* light sweep across the art on hover */
  .role-sheen {
    position: absolute;
    inset: 0;
    z-index: 3;
    background: linear-gradient(115deg, transparent 38%, color-mix(in srgb, var(--c) 28%, transparent) 50%, transparent 62%);
    transform: translateX(-120%);
    transition: transform 0.7s ease;
    pointer-events: none;
  }
  .role-card:hover .role-sheen { transform: translateX(120%); }

  /* playing-card corner index */
  .role-index {
    position: absolute;
    top: 12px; right: 14px;
    z-index: 3;
    font-size: 1.05rem;
    font-weight: 800;
    letter-spacing: 1px;
    color: #fff;
    opacity: 0.92;
    text-shadow: 0 2px 8px rgba(0,0,0,0.6);
  }

  .role-team {
    position: absolute;
    left: 12px; bottom: 12px;
    z-index: 3;
    display: inline-flex;
    align-items: center;
    gap: 6px;
    font-size: 0.66rem;
    font-weight: 700;
    text-transform: uppercase;
    letter-spacing: 1.2px;
    padding: 4px 11px 4px 9px;
    border-radius: 50px;
    color: var(--tc);
    background: color-mix(in srgb, var(--tc) 22%, rgba(0,0,0,0.55));
    border: 1px solid color-mix(in srgb, var(--tc) 45%, transparent);
    backdrop-filter: blur(4px);
  }
  .role-team-dot {
    width: 6px; height: 6px; border-radius: 50%;
    background: var(--tc);
    box-shadow: 0 0 8px var(--tc);
  }

  /* ── Card body ──────────────────────────────────────────────── */
  .role-body {
    position: relative;
    z-index: 2;
    padding: 6px 20px 22px;
    margin-top: -6px;
  }
  .role-name {
    font-size: 1.3rem;
    font-weight: 700;
    margin-bottom: 8px;
    color: var(--text);
  }
  .role-desc {
    color: var(--text-muted);
    font-size: 0.92rem;
    line-height: 1.65;
  }

  @media (max-width: 480px) {
    .roles-grid { grid-template-columns: 1fr; gap: 14px; }
    .role-body { padding: 6px 14px 18px; }
    .role-name { font-size: 1.1rem; }
    .role-desc { font-size: 0.85rem; }
  }
</style>
