---
import { COPY, type Lang } from "../i18n/copy";
import Icon from "./Icon.astro";
interface Props { lang?: Lang }
const { lang = "uz" } = Astro.props;
const t = COPY[lang].featuresSection;
---

<section id="features">
  <div class="container">
    <div class="section-header fade-in">
      <span class="section-label">{t.label}</span>
      <h2 class="section-title">{t.title}</h2>
      <p class="section-subtitle">{t.subtitle}</p>
    </div>

    <div class="feat-grid">
      {t.items.map((f, i) => (
        <article class="feat-card fade-in" style={`transition-delay:${(i % 3) * 70}ms;`}>
          <div class="feat-icon"><Icon name={f.icon} size={26} /></div>
          <h3 class="feat-title">{f.title}</h3>
          <p class="feat-text">{f.text}</p>
        </article>
      ))}
    </div>
  </div>
</section>

<style>
  .feat-grid {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(290px, 1fr));
    gap: 18px;
  }
  .feat-card {
    padding: 30px 26px;
    background: var(--card);
    border: 1px solid var(--border-light);
    border-radius: var(--radius);
    transition: transform 0.25s, border-color 0.25s, box-shadow 0.25s, opacity 0.7s, translate 0.7s;
  }
  .feat-card:hover {
    transform: translateY(-6px);
    border-color: rgba(196, 30, 58, 0.4);
    box-shadow: 0 18px 44px -16px rgba(196, 30, 58, 0.5);
  }
  .feat-icon {
    width: 60px; height: 60px;
    border-radius: 16px;
    display: grid; place-items: center;
    color: var(--gold-light);
    margin-bottom: 18px;
    background: linear-gradient(135deg, rgba(196, 30, 58, 0.16), rgba(212, 175, 55, 0.12));
    border: 1px solid var(--border);
    box-shadow: inset 0 1px 0 rgba(255, 255, 255, 0.05);
    transition: color 0.25s, border-color 0.25s, transform 0.25s;
  }
  .feat-card:hover .feat-icon { color: #fff; border-color: rgba(196, 30, 58, 0.45); transform: translateY(-2px); }
  .feat-title { font-family: var(--font-display); font-size: 1.3rem; font-weight: 700; margin-bottom: 10px; }
  .feat-text { color: var(--text-muted); font-size: 0.96rem; line-height: 1.7; }
</style>
