---
import { BLOG_UI, type BlogLang } from "../i18n/blog";
import { PLAY_URL, CHANNEL_URL } from "../i18n/copy";
import Icon from "./Icon.astro";
interface Props { lang: BlogLang }
const { lang } = Astro.props;
const ui = BLOG_UI[lang];
---

<section class="bcta">
  <div class="bcta-box">
    <img src="/logo.png" alt="" class="bcta-mark" width="78" height="80" aria-hidden="true" />
    <h2 class="bcta-title font-display">{ui.ctaTitle}</h2>
    <p class="bcta-text">{ui.ctaText}</p>
    <div class="bcta-btns">
      <a href={PLAY_URL} class="btn-gold btn-pulse" target="_blank" rel="noopener"><Icon name="play" size={17} /> {ui.ctaPlay}</a>
      <a href={CHANNEL_URL} class="btn-secondary" target="_blank" rel="noopener">{ui.ctaChannel}</a>
    </div>
  </div>
</section>

<style>
  .bcta { padding: 30px 24px 10px; }
  .bcta-box {
    position: relative;
    max-width: 760px;
    margin: 0 auto;
    text-align: center;
    padding: 48px 28px;
    border-radius: 24px;
    overflow: hidden;
    background:
      radial-gradient(circle at 50% 0%, rgba(196, 30, 58, 0.16), transparent 60%),
      linear-gradient(180deg, var(--bg-2), var(--card));
    border: 1px solid var(--border);
  }
  .bcta-mark { display: block; height: 80px; width: auto; margin: 0 auto 14px; filter: drop-shadow(0 8px 24px rgba(212, 175, 55, 0.45)); }
  .bcta-title { font-size: clamp(1.5rem, 4vw, 2.1rem); font-weight: 900; margin-bottom: 10px; }
  .bcta-text { color: var(--text-muted); font-size: 1.05rem; max-width: 460px; margin: 0 auto 26px; line-height: 1.7; }
  .bcta-btns { display: flex; gap: 14px; justify-content: center; flex-wrap: wrap; }
  @media (max-width: 480px) {
    .bcta-btns :global(.btn-gold), .bcta-btns :global(.btn-secondary) { width: 100%; justify-content: center; }
  }
</style>
