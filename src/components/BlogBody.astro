---
// Renders a post body (array of content blocks) as styled prose.
import { BLOG_UI, type Block, type BlogLang } from "../i18n/blog";
interface Props { blocks: Block[]; lang?: BlogLang }
const { blocks, lang = "uz" } = Astro.props;
const ui = BLOG_UI[lang];

const hostOf = (url: string) => {
  try { return new URL(url).hostname.replace(/^www\./, ""); } catch { return url; }
};
---

<div class="prose">
  {blocks.map((b) =>
    "h2" in b ? (
      <h2>{b.h2}</h2>
    ) : "h3" in b ? (
      <h3>{b.h3}</h3>
    ) : "ul" in b ? (
      <ul>{b.ul.map((li) => <li>{li}</li>)}</ul>
    ) : "quote" in b ? (
      <blockquote>{b.quote}</blockquote>
    ) : "answer" in b ? (
      <aside class="answer-box" role="note" aria-label={ui.answerLabel}>
        <span class="answer-label">{ui.answerLabel}</span>
        <p>{b.answer}</p>
      </aside>
    ) : "table" in b ? (
      <div class="table-wrap">
        <table>
          <thead>
            <tr>{b.table.head.map((h) => <th>{h}</th>)}</tr>
          </thead>
          <tbody>
            {b.table.rows.map((row) => (
              <tr>{row.map((cell) => <td set:html={cell} />)}</tr>
            ))}
          </tbody>
        </table>
      </div>
    ) : "sources" in b ? (
      <div class="sources">
        <div class="sources-title">{ui.sourcesLabel}</div>
        <ul>
          {b.sources.map((s) => (
            <li>
              <a href={s.url} target="_blank" rel="noopener nofollow">{s.label}</a>
              <span class="src-host">{hostOf(s.url)}</span>
            </li>
          ))}
        </ul>
      </div>
    ) : (
      <p set:html={"p" in b ? b.p : ""} />
    )
  )}
</div>

<style>
  .prose { color: var(--text-muted); font-size: 1.08rem; line-height: 1.85; }
  .prose > * + * { margin-top: 1.15em; }

  .prose h2 {
    font-family: var(--font-display);
    color: var(--text);
    font-size: clamp(1.35rem, 3vw, 1.7rem);
    font-weight: 800;
    line-height: 1.25;
    margin-top: 2em;
    padding-left: 16px;
    border-left: 3px solid var(--accent, var(--primary));
  }
  .prose h3 {
    color: var(--text);
    font-size: 1.18rem;
    font-weight: 700;
    margin-top: 1.6em;
  }
  .prose p { color: var(--text-muted); }
  .prose strong { color: var(--text); }
  .prose :global(a) { color: var(--accent, var(--primary)); font-weight: 600; }
  .prose :global(a:hover) { text-decoration: underline; }

  .prose ul { list-style: none; display: flex; flex-direction: column; gap: 12px; }
  .prose li {
    position: relative;
    padding-left: 30px;
    color: var(--text-muted);
  }
  .prose li::before {
    content: "";
    position: absolute;
    left: 6px; top: 0.62em;
    width: 8px; height: 8px;
    border-radius: 50%;
    background: var(--accent, var(--primary));
    box-shadow: 0 0 10px var(--accent, var(--primary));
  }

  .prose blockquote {
    margin-top: 2em;
    padding: 22px 26px;
    border-radius: var(--radius-sm);
    border: 1px solid var(--border-light);
    border-left: 4px solid var(--gold);
    background: rgba(212, 175, 55, 0.05);
    color: var(--text);
    font-size: 1.15rem;
    font-style: italic;
    line-height: 1.7;
  }

  /* ── Answer box (AEO "Qisqa javob") ── */
  .answer-box {
    margin-top: 1.6em;
    padding: 18px 22px;
    border-radius: var(--radius-sm);
    border: 1px solid color-mix(in srgb, var(--accent, var(--primary)) 35%, transparent);
    background: color-mix(in srgb, var(--accent, var(--primary)) 7%, transparent);
  }
  .answer-box .answer-label {
    display: inline-block;
    font-size: 0.72rem;
    font-weight: 800;
    text-transform: uppercase;
    letter-spacing: 1.5px;
    color: var(--accent, var(--primary));
    margin-bottom: 8px;
  }
  .answer-box p { color: var(--text); font-size: 1.05rem; line-height: 1.7; margin: 0; }

  /* ── Comparison table ── */
  .table-wrap { overflow-x: auto; border: 1px solid var(--border-light); border-radius: var(--radius-sm); }
  .table-wrap table { width: 100%; border-collapse: collapse; font-size: 0.96rem; }
  .table-wrap th, .table-wrap td { padding: 12px 16px; text-align: left; vertical-align: top; }
  .table-wrap thead th {
    background: color-mix(in srgb, var(--accent, var(--primary)) 12%, transparent);
    color: var(--text); font-weight: 700;
  }
  .table-wrap tbody tr { border-top: 1px solid var(--border-light); }
  .table-wrap tbody td { color: var(--text-muted); }
  .table-wrap tbody td:first-child { color: var(--text); font-weight: 600; }

  /* ── Sources ── */
  .sources {
    margin-top: 2em;
    padding: 18px 22px;
    border-radius: var(--radius-sm);
    border: 1px solid var(--border-light);
    background: rgba(255, 255, 255, 0.015);
    font-size: 0.95rem;
  }
  .sources-title { font-weight: 700; color: var(--text); margin-bottom: 10px; }
  .sources ul { list-style: none; display: flex; flex-direction: column; gap: 8px; }
  .sources li { padding-left: 0; }
  .sources li::before { display: none; }
  .sources a { color: var(--accent, var(--primary)); font-weight: 600; }
  .sources a:hover { text-decoration: underline; }
  .src-host { color: var(--text-dim); font-size: 0.85rem; margin-left: 8px; }
</style>
