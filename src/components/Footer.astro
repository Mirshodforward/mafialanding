---
import { COPY, PLAY_URL, BOT_URL, CHANNEL_URL, type Lang } from "../i18n/copy";
import Icon from "./Icon.astro";
interface Props { lang?: Lang }
const { lang = "uz" } = Astro.props;
const t = COPY[lang].footer;
const nav = COPY[lang].nav;
const base = lang === "ru" ? "/ru" : "";
const year = new Date().getFullYear();
---

<footer class="footer">
  <div class="container footer-inner">
    <div class="footer-brand">
      <a href={base || "/"} class="brand">
        <img src="/logo.png" alt="" class="footer-mark" width="41" height="42" />
        <span class="brand-name font-display">MAFIA <span class="text-gold">ONLINE</span></span>
      </a>
      <p class="footer-tag">{t.tagline}</p>
    </div>

    <div class="footer-col">
      <h4>{t.product}</h4>
      <a href={`${base}#roles`}>{nav.roles}</a>
      <a href={`${base}#features`}>{nav.features}</a>
      <a href={`${base}#how`}>{nav.how}</a>
      <a href={`${base}#faq`}>{nav.faq}</a>
      <a href={`${base}/blog`}>{nav.blog}</a>
    </div>

    <div class="footer-col">
      <h4>{t.community}</h4>
      <a href={PLAY_URL} target="_blank" rel="noopener">{t.play} ↗</a>
      <a href={BOT_URL} target="_blank" rel="noopener">{t.bot} ↗</a>
      <a href={CHANNEL_URL} target="_blank" rel="noopener">{t.channel} ↗</a>
    </div>

    <div class="footer-col">
      <h4>{t.info}</h4>
      <a href={`${base}/about`}>{t.about}</a>
      <a href={`${base}/contact`}>{t.contact}</a>
      <a href={`${base}/privacy`}>{t.privacy}</a>
      <a href={`${base}/terms`}>{t.terms}</a>
    </div>

    <div class="footer-col">
      <h4>Til / Язык</h4>
      <a href="/">O'zbekcha</a>
      <a href="/ru">Русский</a>
    </div>
  </div>

  <div class="footer-bottom">
    <div class="container footer-bottom-inner">
      <span>© {year} Mafia Online. {t.rights}</span>
      <a href={PLAY_URL} class="btn-primary footer-play" target="_blank" rel="noopener"><Icon name="play" size={15} /> {nav.play}</a>
    </div>
  </div>
</footer>

<style>
  .footer { border-top: 1px solid var(--border-light); background: var(--bg-2); padding-top: 60px; }
  .footer-inner {
    display: grid;
    grid-template-columns: 2fr 1fr 1fr 1fr 1fr;
    gap: 36px;
    padding-bottom: 48px;
  }
  .footer-brand .brand { display: inline-flex; align-items: center; gap: 10px; margin-bottom: 16px; }
  .footer-mark { height: 42px; width: auto; filter: drop-shadow(0 2px 10px rgba(212, 175, 55, 0.35)); }
  .brand-name { font-size: 1.2rem; font-weight: 800; letter-spacing: 1px; }
  .footer-tag { color: var(--text-muted); font-size: 0.95rem; line-height: 1.7; max-width: 320px; }

  .footer-col h4 {
    font-size: 0.8rem;
    text-transform: uppercase;
    letter-spacing: 1.5px;
    color: var(--text-dim);
    margin-bottom: 16px;
  }
  .footer-col a {
    display: block;
    color: var(--text-muted);
    font-size: 0.95rem;
    padding: 6px 0;
    transition: color 0.2s;
  }
  .footer-col a:hover { color: var(--text); }

  .footer-bottom { border-top: 1px solid var(--border-light); padding: 22px 0; }
  .footer-bottom-inner {
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 16px;
    flex-wrap: wrap;
    color: var(--text-dim);
    font-size: 0.9rem;
  }
  .footer-play { padding: 10px 22px; font-size: 0.9rem; }

  @media (max-width: 760px) {
    .footer-inner { grid-template-columns: 1fr 1fr; gap: 32px; }
    .footer-brand { grid-column: 1 / -1; }
  }
  @media (max-width: 440px) {
    .footer-inner { grid-template-columns: 1fr; }
    .footer-bottom-inner { flex-direction: column; text-align: center; }
    .footer-play { width: 100%; justify-content: center; }
  }
</style>
