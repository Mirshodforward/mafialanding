---
import { BLOG_UI, POSTS, type BlogLang } from "../i18n/blog";
import BlogHeader from "./BlogHeader.astro";
import BlogFooter from "./BlogFooter.astro";
import BlogCard from "./BlogCard.astro";
import BlogCTA from "./BlogCTA.astro";
interface Props { lang: BlogLang }
const { lang } = Astro.props;
const ui = BLOG_UI[lang];
---

<BlogHeader lang={lang} />

<main>
  <header class="bidx-hero">
    <span class="section-label">{ui.indexLabel}</span>
    <h1 class="bidx-title font-display">{ui.indexTitle}</h1>
    <p class="bidx-sub">{ui.indexSubtitle}</p>
  </header>

  <div class="container bidx-grid">
    {POSTS.map((post, i) => <BlogCard post={post} lang={lang} index={i} />)}
  </div>

  <BlogCTA lang={lang} />
</main>

<BlogFooter lang={lang} />

<style>
  .bidx-hero { max-width: 760px; margin: 0 auto; text-align: center; padding: 70px 24px 40px; }
  .bidx-title { font-size: clamp(2rem, 5vw, 3rem); font-weight: 900; line-height: 1.15; margin-bottom: 16px; }
  .bidx-sub { color: var(--text-muted); font-size: 1.12rem; line-height: 1.7; }

  .bidx-grid {
    display: grid;
    grid-template-columns: repeat(2, 1fr);
    gap: 24px;
    padding-top: 20px;
    padding-bottom: 20px;
  }
  @media (max-width: 760px) {
    .bidx-grid { grid-template-columns: 1fr; }
  }
</style>
