---
// Sticky header for the blog (UZ / RU / EN). Self-contained so it works on the
// English pages too, which have no full marketing site behind them.
import { BLOG_UI, BLOG_LANGS, blogIndexPath, postPath, homePath, type BlogLang } from "../i18n/blog";
import { PLAY_URL } from "../i18n/copy";
import Icon from "./Icon.astro";

interface Props { lang: BlogLang; slug?: string }
const { lang, slug } = Astro.props;
const ui = BLOG_UI[lang];
const langHref = (l: BlogLang) => (slug ? postPath(l, slug) : blogIndexPath(l));
---

<header class="bnav">
  <div class="bnav-inner">
    <a href={homePath(lang)} class="bbrand" aria-label="Mafia Online">
      <img src="/logo.png" alt="" class="bbrand-mark" width="36" height="37" />
      <span class="bbrand-name font-display">MAFIA<span class="text-gold"> ONLINE</span></span>
    </a>

    <nav class="bnav-links" id="bnavLinks">
      <a href={homePath(lang)}>{ui.nav.home}</a>
      <a href={blogIndexPath(lang)} aria-current={!slug ? "page" : undefined}>{ui.nav.blog}</a>
    </nav>

    <div class="bnav-actions">
      <div class="blang blang-desktop" role="group" aria-label="Language">
        {BLOG_LANGS.map((l) => (
          <a href={langHref(l)} class:list={["blang-opt", { active: l === lang }]}>{l.toUpperCase()}</a>
        ))}
      </div>
      <a href={PLAY_URL} class="btn-primary bnav-play bnav-play-desktop" target="_blank" rel="noopener">
        <Icon name="play" size={15} /> <span>{ui.nav.play}</span>
      </a>
      <button class="bnav-burger" id="bnavBurger" type="button" aria-label="Menu" aria-expanded="false" aria-controls="bnavLinks">
        <span></span><span></span><span></span>
      </button>
    </div>
  </div>
</header>

<script>
  const burger = document.getElementById("bnavBurger");
  const links = document.getElementById("bnavLinks");
  const bnav = burger?.closest(".bnav");

  const setOpen = (open: boolean) => {
    if (!burger || !links || !bnav) return;
    bnav.classList.toggle("is-open", open);
    burger.classList.toggle("is-active", open);
    burger.setAttribute("aria-expanded", String(open));
    document.body.classList.toggle("nav-open", open);
  };

  burger?.addEventListener("click", () => setOpen(!bnav?.classList.contains("is-open")));
  links?.querySelectorAll("a").forEach((a) => a.addEventListener("click", () => setOpen(false)));
  window.matchMedia("(min-width: 721px)").addEventListener("change", (e) => {
    if (e.matches) setOpen(false);
  });
</script>

<style>
  .bnav {
    position: sticky;
    top: 0;
    z-index: 1000;
    background: rgba(10, 10, 15, 0.92);
    backdrop-filter: blur(14px);
    border-bottom: 1px solid var(--border-light);
  }
  .bnav-inner {
    max-width: var(--maxw);
    margin: 0 auto;
    padding: 12px max(16px, env(safe-area-inset-right)) 12px max(16px, env(safe-area-inset-left));
    display: flex;
    align-items: center;
    gap: 16px;
    min-height: 44px;
  }
  .bbrand { display: flex; align-items: center; gap: 10px; flex-shrink: 0; min-width: 0; }
  .bbrand-mark { height: 36px; width: auto; filter: drop-shadow(0 2px 10px rgba(212, 175, 55, 0.45)); }
  .bbrand-name { font-size: clamp(1rem, 3.5vw, 1.18rem); font-weight: 800; letter-spacing: 0.5px; white-space: nowrap; }

  .bnav-links { display: flex; gap: 26px; margin-left: auto; }
  .bnav-links a {
    color: var(--text-muted);
    font-weight: 500;
    font-size: 0.95rem;
    transition: color 0.2s;
  }
  .bnav-links a:hover, .bnav-links a[aria-current="page"] { color: var(--text); }

  .bnav-actions { display: flex; align-items: center; gap: 12px; flex-shrink: 0; }
  .blang { display: inline-flex; border: 1px solid var(--border); border-radius: 10px; overflow: hidden; }
  .blang-opt {
    padding: 7px 11px;
    font-size: 0.78rem; font-weight: 700;
    color: var(--text-dim);
    transition: color 0.2s, background 0.2s;
  }
  .blang-opt:hover { color: var(--text); }
  .blang-opt.active { color: var(--text); background: rgba(196, 30, 58, 0.18); }
  .bnav-play { padding: 10px 20px; font-size: 0.9rem; box-shadow: 0 6px 20px rgba(196, 30, 58, 0.3); white-space: nowrap; }

  .bnav-burger {
    display: none;
    flex-direction: column;
    justify-content: center;
    gap: 5px;
    width: 44px;
    height: 44px;
    background: rgba(255, 255, 255, 0.04);
    border: 1px solid var(--border);
    border-radius: 12px;
    cursor: pointer;
    padding: 10px;
    -webkit-tap-highlight-color: transparent;
  }
  .bnav-burger span {
    display: block;
    width: 100%;
    height: 2px;
    background: var(--text);
    border-radius: 2px;
    transition: transform 0.25s, opacity 0.25s;
  }
  .bnav-burger.is-active span:nth-child(1) { transform: translateY(7px) rotate(45deg); }
  .bnav-burger.is-active span:nth-child(2) { opacity: 0; }
  .bnav-burger.is-active span:nth-child(3) { transform: translateY(-7px) rotate(-45deg); }

  @media (max-width: 720px) {
    .blang-desktop,
    .bnav-play-desktop { display: none !important; }
    .bnav-burger { display: flex; }

    .bnav-links {
      position: fixed;
      left: 0;
      right: 0;
      top: 68px;
      margin: 0;
      flex-direction: column;
      gap: 0;
      padding: 8px max(16px, env(safe-area-inset-left)) 16px max(16px, env(safe-area-inset-right));
      background: rgba(10, 10, 15, 0.98);
      backdrop-filter: blur(16px);
      border-bottom: 1px solid var(--border-light);
      max-height: 0;
      overflow: hidden;
      opacity: 0;
      visibility: hidden;
      pointer-events: none;
      transition: max-height 0.3s, opacity 0.25s, visibility 0.25s;
      z-index: 999;
    }
    .bnav-links a {
      padding: 14px 4px;
      font-size: 1.05rem;
      border-bottom: 1px solid var(--border-light);
    }
    .bnav.is-open .bnav-links {
      max-height: 240px;
      opacity: 1;
      visibility: visible;
      pointer-events: auto;
    }
  }

  @media (max-width: 460px) {
    .bbrand-name span.text-gold { display: none; }
  }
</style>
