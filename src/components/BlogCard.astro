---
import { BLOG_UI, postPath, type BlogPost, type BlogLang } from "../i18n/blog";
interface Props { post: BlogPost; lang: BlogLang; index?: number }
const { post, lang, index = 0 } = Astro.props;
const ui = BLOG_UI[lang];
const c = post[lang];
---

<a
  href={postPath(lang, post.slug)}
  class="bcard fade-in"
  style={`--accent:${post.accent}; transition-delay:${index * 60}ms;`}
>
  <div class="bcard-head">
    <span class="bcard-tag">{post.tag[lang]}</span>
    <span class="bcard-read">{post.readMins} {ui.minRead}</span>
  </div>
  <h2 class="bcard-title font-display">{c.title}</h2>
  <p class="bcard-excerpt">{c.excerpt}</p>
  <span class="bcard-more">{ui.readMore} →</span>
</a>

<style>
  .bcard {
    display: flex;
    flex-direction: column;
    padding: 26px 26px 24px;
    border-radius: var(--radius);
    background: linear-gradient(165deg, var(--card-hover), #0b0b12);
    border: 1px solid var(--border-light);
    box-shadow: 0 18px 40px -28px rgba(0, 0, 0, 0.9);
    transition: transform 0.25s, border-color 0.25s, box-shadow 0.25s, opacity 0.7s, translate 0.7s;
    overflow: hidden;
    position: relative;
  }
  .bcard::before {
    content: "";
    position: absolute;
    inset: 0 0 auto 0;
    height: 3px;
    background: linear-gradient(90deg, transparent, var(--accent), transparent);
    opacity: 0.8;
  }
  .bcard:hover {
    transform: translateY(-6px);
    border-color: color-mix(in srgb, var(--accent) 55%, var(--border));
    box-shadow: 0 30px 60px -30px color-mix(in srgb, var(--accent) 70%, black);
  }

  .bcard-head { display: flex; align-items: center; justify-content: space-between; gap: 12px; margin-bottom: 16px; }
  .bcard-tag {
    font-size: 0.72rem; font-weight: 700;
    text-transform: uppercase; letter-spacing: 1.4px;
    color: var(--accent);
    padding: 5px 12px;
    border-radius: 50px;
    background: color-mix(in srgb, var(--accent) 14%, transparent);
    border: 1px solid color-mix(in srgb, var(--accent) 34%, transparent);
  }
  .bcard-read { font-size: 0.8rem; color: var(--text-dim); }

  .bcard-title {
    font-size: 1.32rem;
    font-weight: 800;
    line-height: 1.3;
    color: var(--text);
    margin-bottom: 12px;
  }
  .bcard-excerpt {
    color: var(--text-muted);
    font-size: 0.97rem;
    line-height: 1.7;
    flex: 1;
  }
  .bcard-more {
    margin-top: 20px;
    font-weight: 700;
    font-size: 0.92rem;
    color: var(--accent);
  }
</style>
